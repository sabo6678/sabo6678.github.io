---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-lg bg-dark-bg/70 border-b border-dark-border">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight">
      <span class="neon-text-cyan">sabo</span><span class="text-white/60">.dev</span>
    </a>
    <ul class="flex gap-8 text-sm">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class={`transition-colors duration-200 ${
              currentPath === item.href
                ? 'text-neon-cyan'
                : 'text-white/50 hover:text-white/90'
            }`}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
