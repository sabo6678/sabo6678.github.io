---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: '个人网站',
    description: '你现在看到的这个网站，基于 Astro + React + Tailwind CSS 构建，部署在 GitHub Pages。',
    tags: ['Astro', 'React', 'Tailwind', 'GitHub Pages'],
    link: 'https://github.com/sabo/sabo.github.io',
  },
  {
    name: 'Coming Soon',
    description: '更多项目正在路上...',
    tags: ['...'],
    link: '#',
  },
];
---

<BaseLayout title="Projects" description="Things I've built">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-extrabold mb-4">
      <span class="neon-text-purple">Projects</span>
    </h1>
    <p class="text-white/40 mb-12">Things I've built and contributed to.</p>

    <div class="grid gap-6">
      {projects.map(project => (
        <a href={project.link}
           class="block p-6 rounded-xl bg-dark-card border border-dark-border
                  hover:border-neon-purple/30 hover:neon-border-purple
                  transition-all duration-300 hover:-translate-y-1">
          <h2 class="text-xl font-semibold text-white">{project.name}</h2>
          <p class="text-sm text-white/40 mt-2">{project.description}</p>
          <div class="flex flex-wrap gap-2 mt-4">
            {project.tags.map(tag => (
              <span class="px-2 py-1 text-xs rounded-md bg-neon-purple/10 text-neon-purple border border-neon-purple/20">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
