---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <div class="max-w-3xl mx-auto px-6 py-20">
    <article class="prose prose-invert prose-lg max-w-none">
      <time class="text-sm text-white/30">
        {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
      </time>
      <h1 class="text-4xl font-extrabold mt-2 mb-8 neon-text-purple">{post.data.title}</h1>
      <div class="text-white/70 leading-relaxed space-y-4">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
