---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParticleBackground from '../components/ParticleBackground.tsx';
import TypewriterTitle from '../components/TypewriterTitle.tsx';
---

<BaseLayout title="Home" description="sabo — Developer, Creator, Explorer">
  <div class="relative min-h-[calc(100vh-8rem)] flex items-center justify-center overflow-hidden">
    <ParticleBackground client:load />

    <div class="text-center z-10 px-6">
      <!-- Avatar / Logo area -->
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-gradient-to-br from-neon-cyan/20 to-neon-purple/20 border border-neon-cyan/30 neon-border">
          <span class="text-4xl font-black neon-text-cyan">S</span>
        </div>
      </div>

      <!-- Main heading -->
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-4">
        <span class="text-white">Hello, I'm </span>
        <span class="neon-text-purple">sabo</span>
      </h1>

      <!-- Typewriter -->
      <p class="text-2xl md:text-3xl text-white/40 font-light mb-12 h-10">
        我是一个 <TypewriterTitle client:load />
      </p>

      <!-- Navigation cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-2xl mx-auto">
        <a href="/blog"
           class="group p-6 rounded-xl bg-dark-card border border-dark-border
                  hover:border-neon-cyan/50 hover:neon-border
                  transition-all duration-300 hover:-translate-y-1">
          <div class="text-3xl mb-2">📝</div>
          <h3 class="text-lg font-semibold text-white group-hover:text-neon-cyan transition-colors">Blog</h3>
          <p class="text-sm text-white/40 mt-1">Thoughts &amp; writings</p>
        </a>
        <a href="/projects"
           class="group p-6 rounded-xl bg-dark-card border border-dark-border
                  hover:border-neon-purple/50 hover:neon-border-purple
                  transition-all duration-300 hover:-translate-y-1">
          <div class="text-3xl mb-2">🚀</div>
          <h3 class="text-lg font-semibold text-white group-hover:text-neon-purple transition-colors">Projects</h3>
          <p class="text-sm text-white/40 mt-1">Things I've built</p>
        </a>
        <a href="/about"
           class="group p-6 rounded-xl bg-dark-card border border-dark-border
                  hover:border-neon-pink/50 hover:neon-border-pink
                  transition-all duration-300 hover:-translate-y-1 sm:col-span-2 lg:col-span-1">
          <div class="text-3xl mb-2">👋</div>
          <h3 class="text-lg font-semibold text-white group-hover:text-neon-pink transition-colors">About</h3>
          <p class="text-sm text-white/40 mt-1">Who I am</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
